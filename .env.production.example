DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=180

# Replace this with the real public URL. Do not add a trailing slash.
FRONTEND_ORIGINS=https://compass.example.com

# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-at-least-64-random-characters
AUTH_TOKEN_HOURS=72

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_DISPLAY_NAME=系统管理员

# Use 80 when another reverse proxy or cloud load balancer handles HTTPS.
HTTP_PORT=80
