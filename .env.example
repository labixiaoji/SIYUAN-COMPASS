DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=180

# Local frontend dev server and Docker/Nginx frontend origins.
# For production, replace these with your real public URL.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost

# Local Vite dev server reads this from the root .env.
# Docker frontend builds still use /api through docker-compose.yml.
VITE_API_BASE_URL=http://localhost:8000/api

# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-at-least-64-random-characters
AUTH_TOKEN_HOURS=72

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_DISPLAY_NAME=系统管理员

POSTGRES_DB=siyuan_compass
POSTGRES_USER=siyuan
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Use 8080 for local Docker. Use 80 when another reverse proxy or cloud load balancer handles HTTPS.
HTTP_PORT=8080
